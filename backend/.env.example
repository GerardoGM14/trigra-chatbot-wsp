# Copia este archivo a .env y rellena los valores.
# El servidor falla rápido al arrancar si falta alguna variable obligatoria.

# --- HTTP ---
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Origen permitido por CORS (frontend en dev = Vite por defecto).
# En producción será el dominio de Firebase Hosting.
CORS_ORIGIN=http://localhost:5173

# --- Base de datos ---
DATABASE_URL=postgresql://wsp_user:wsp_password@localhost:5432/wsp_control

# --- Redis (BullMQ + cache) ---
REDIS_URL=redis://localhost:6379
# Prefijo de claves para no chocar con otras apps que compartan Redis.
REDIS_PREFIX=wsp

# --- JWT ---
# Genera un secret aleatorio: `openssl rand -hex 32`
JWT_SECRET=cambia-esto-en-produccion-con-un-secret-aleatorio-largo
JWT_EXPIRES_IN=8h

# --- Rutas en disco ---
# En producción apunta a /var/lib/wsp-control/uploads y /var/lib/wsp-control/baileys-auth
UPLOAD_DIR=./uploads
BAILEYS_AUTH_DIR=./baileys-auth

# --- Política de envíos por defecto (puede sobreescribirse en runtime) ---
SEND_RATE_PER_MINUTE=60
SEND_PAUSE_MIN_SECONDS=2
SEND_PAUSE_MAX_SECONDS=6
