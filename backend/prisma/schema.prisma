// Schema Prisma para WSP Control.
// Convenciones:
//   · IDs internos: cuid()    (cortos, ordenables, k-safe)
//   · IDs públicos: campo `slug` cuando hace falta exponer algo human-readable
//   · Enums para roles/estados/niveles → consistencia con el frontend
//   · created/updated en todos los modelos persistentes

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USUARIOS ============
enum UserRole {
  Operador
  Supervisor
  Administrador
}

enum UserStatus {
  Activo
  Suspendido
  Invitado
}

model User {
  id           String     @id @default(cuid())
  // Slug corto para mostrar como @username en logs/UI (maria.q, lucia.r).
  username     String     @unique
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(Operador)
  status       UserStatus @default(Activo)
  lastSeen     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  campaigns        Campaign[]          @relation("CampaignOwner")
  sessions         SessionAssignment[]
  activity         ActivityLog[]
  conversations    Conversation[]      @relation("ConvAssignedUser")
  sentMessages     Message[]           @relation("MsgSentByUser")

  @@index([status])
  @@index([role])
}

// ============ SESIONES BAILEYS ============
enum SessionStatus {
  Conectado
  Reconectando
  Desconectado
}

model BaileysSession {
  id              String        @id @default(cuid())
  // ID legible que se usa en logs y la UI: session_01, session_02…
  slug            String        @unique
  phoneNumber     String        @unique
  status          SessionStatus @default(Desconectado)
  quality         String? // "Alta" | "Media" | "Baja" | "—"
  platform        String? // "Android" | "iOS"
  exclusive       Boolean       @default(false)
  exclusiveUserId String? // si exclusive=true, el operador con acceso único
  connectedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  assignments   SessionAssignment[]
  campaigns     Campaign[]
  conversations Conversation[]

  @@index([status])
}

// Tabla puente N:M entre sesiones y operadores (modo compartido).
model SessionAssignment {
  sessionId String
  userId    String
  createdAt DateTime @default(now())

  session BaileysSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
}

// ============ GRUPOS Y CONTACTOS ============
model ContactGroup {
  id        String   @id @default(cuid())
  slug      String   @unique // grp_clientes_a, grp_vip, ...
  name      String
  tag       String // "Clientes" | "VIP" | "Leads" | ...
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts       Contact[]
  campaignGroups CampaignGroup[]

  @@index([tag])
}

model Contact {
  id        String   @id @default(cuid())
  phone     String // E.164: +51998412003
  name      String?
  tags      String[] // ["VIP", "Lima"] - Postgres arrays nativos
  optedOut  Boolean  @default(false)
  groupId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, phone]) // un número puede repetirse entre grupos, no dentro
  @@index([phone])
}

// ============ PLANTILLAS ============
enum TemplateType {
  Texto
  Lista
  Botones
  Media
}

model Template {
  id        String       @id @default(cuid())
  slug      String       @unique // tpl_horarios, tpl_pago, ...
  name      String
  type      TemplateType
  body      String       @db.Text
  // items y meta variables se guardan como JSON para flexibilidad
  // (opciones de lista, botones, variables disponibles).
  items     Json? // [{title, desc}] o [{label, action}]
  usedCount Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  campaigns Campaign[]

  @@index([type])
}

// ============ CAMPAÑAS ============
enum CampaignStatus {
  Borrador
  Programada
  Enviando
  Pausada
  Completada
  Archivada
}

enum CampaignType {
  Texto
  Imagen
  Video
  Documento
  Lista
  Botones
}

model Campaign {
  id            String         @id @default(cuid())
  slug          String         @unique // camp_8821, camp_8820, ...
  name          String
  status        CampaignStatus @default(Borrador)
  type          CampaignType
  body          String         @db.Text
  // Mismo shape que Template.items - duplicamos al "snapshot" para que cambios
  // posteriores en la plantilla NO afecten campañas ya enviadas.
  items         Json?
  // Programación
  scheduledAt   DateTime?
  recurringRule String? // formato RRULE de iCalendar para recurrentes
  // Estado de envío
  total         Int            @default(0)
  sent          Int            @default(0)
  failed        Int            @default(0)
  progress      Int            @default(0) // 0..100

  ownerId    String
  templateId String? // si arrancó desde una plantilla
  sessionId  String? // sesión Baileys asignada al envío
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner    User            @relation("CampaignOwner", fields: [ownerId], references: [id])
  template Template?       @relation(fields: [templateId], references: [id])
  session  BaileysSession? @relation(fields: [sessionId], references: [id])
  groups   CampaignGroup[]
  sendJobs SendJob[]

  @@index([status])
  @@index([ownerId])
  @@index([scheduledAt])
}

// Audiencia de la campaña: muchos grupos por campaña.
model CampaignGroup {
  campaignId String
  groupId    String

  campaign Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  group    ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([campaignId, groupId])
}

// ============ TRABAJOS DE ENVÍO ============
// Cada mensaje individual a un contacto es un SendJob. BullMQ los procesa
// con rate limit. Esto nos da reintentos y auditoría a nivel mensaje.
enum SendJobStatus {
  Pendiente
  Enviado
  Fallido
}

model SendJob {
  id           String        @id @default(cuid())
  campaignId   String
  phone        String // snapshot del número (los contactos pueden moverse)
  status       SendJobStatus @default(Pendiente)
  attempts     Int           @default(0)
  errorCode    String?
  errorMessage String?
  sentAt       DateTime?
  createdAt    DateTime      @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
  @@index([phone])
}

// ============ AUDITORÍA ============
enum LogLevel {
  ok
  info
  warn
  err
}

model ActivityLog {
  id        String   @id @default(cuid())
  // Acción namespaceada: campaign.send, contact.import, baileys.qr, auth.failed
  action    String
  // Referencia opcional al recurso afectado (slug, no FK rígido).
  target    String?
  detail    String?
  level     LogLevel @default(info)
  // Si la acción la hizo un usuario, lo enlazamos. system actions van con null.
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([level])
  @@index([userId])
}

// ============ BOT: FLOWS Y NODOS ============
// Un Flow es una conversación predefinida que dispara cuando llega un mensaje
// que matchea su `trigger`. Cada Flow es un grafo dirigido de FlowNode.
//
// Triggers soportados (string libre, parseado en código):
//   · "default"           → primer mensaje sin contexto
//   · "keyword:hola"      → match exacto (case-insensitive)
//   · "regex:^precio"     → match con regex
//   · "fallback"          → cuando ningún otro flow matcheó

enum NodeType {
  message      // bot envía texto; opcionalmente avanza a `nextNodeId`
  menu         // bot envía texto + opciones numeradas; espera respuesta
  handoff      // marca la conversación para que la atienda un operador
  end          // termina el flow; siguiente mensaje del cliente arranca otro
}

model Flow {
  id        String   @id @default(cuid())
  name      String
  // Trigger plano — lo parsea BotEngine. Ver comentario arriba.
  trigger   String   @default("default")
  isActive  Boolean  @default(true)
  // Nodo por el que arranca el flow al dispararse.
  startNodeId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nodes         FlowNode[]
  conversations Conversation[]

  @@index([trigger])
  @@index([isActive])
}

model FlowNode {
  id     String   @id @default(cuid())
  flowId String
  type   NodeType
  // Texto que el bot envía (puede tener variables {{nombre}}).
  body   String   @db.Text
  // Para `menu`: [{label:"Ver catálogo", value:"1", nextNodeId:"..."}].
  // Para `message`: opcionalmente { nextNodeId: "..." } para encadenar.
  options Json?

  flow Flow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
}

// ============ CONVERSACIONES ============
enum ConvStatus {
  bot          // el bot está conduciendo la conversación
  handed_off   // un operador tomó el control, bot deshabilitado
  closed       // conversación cerrada manualmente
}

enum MsgDirection {
  inbound      // del cliente hacia nosotros
  outbound     // de nosotros (bot u operador) al cliente
}

model Conversation {
  id           String     @id @default(cuid())
  sessionId    String     // sesión Baileys por la que entra
  contactPhone String     // E.164 (sin "+", como llega de Baileys)
  contactName  String?    // si está en la libreta de WSP del operador
  status       ConvStatus @default(bot)

  // Estado del flow actual: en qué flow + en qué nodo está esperando input.
  currentFlowId String?
  currentNodeId String?

  // Si un operador tomó el control.
  assignedUserId String?

  lastMessageAt DateTime  @default(now())
  unreadCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  session       BaileysSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  currentFlow   Flow?          @relation(fields: [currentFlowId], references: [id], onDelete: SetNull)
  assignedUser  User?          @relation("ConvAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  messages      Message[]

  // Una conversación por (sesión, número). Si el mismo contacto escribe a
  // otra sesión, es otra conversación independiente.
  @@unique([sessionId, contactPhone])
  @@index([status])
  @@index([assignedUserId])
  @@index([lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  direction      MsgDirection
  body           String       @db.Text
  // Si trae adjunto (futuro): tipo + URL del archivo en disco.
  mediaType      String?      // "image" | "video" | "audio" | "document"
  mediaUrl       String?
  // ID del mensaje en WhatsApp (para deduplicar y referenciar).
  whatsappId     String?      @unique
  // Si lo envió un operador (no el bot), enlazamos al user.
  sentByUserId   String?
  createdAt      DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentByUser   User?        @relation("MsgSentByUser", fields: [sentByUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
}

// ============ POLÍTICAS GLOBALES ============
// Singleton (siempre 1 fila). Cambia las políticas que vienen del .env y se
// pueden sobreescribir desde AdminSettings.
model AccountPolicy {
  id                 String   @id @default(cuid())
  maxRatePerMinute   Int      @default(60)
  pauseMinSeconds    Int      @default(2)
  pauseMaxSeconds    Int      @default(6)
  scheduleWindow     String   @default("Lun–Sáb · 08:00 – 20:00 (UTC−5)")
  lockoutAttempts    Int      @default(5)
  lockoutMinutes     Int      @default(30)
  passwordMaxAgeDays Int      @default(90)
  twoFactorRequired  Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}
