# Copia este archivo a .env.local y rellena con tus credenciales reales.
# .env.local NO se sube al repo (.gitignore lo excluye).
#
# Las claves de Firebase Web son públicas por diseño — viajan en el JS que se
# entrega al navegador. La protección viene de los "Authorized domains" de
# Firebase y de las reglas de seguridad, no del secreto de la clave.

# --- API del backend (cuando se conecte) ---
# En dev local apunta a tu Fastify; en producción al subdominio de la VPS.
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# --- Firebase (Hosting + Analytics) ---
# Saca estos valores de: Firebase Console → Project Settings → Web app SDK.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# measurementId es opcional — solo si activaste Analytics.
VITE_FIREBASE_MEASUREMENT_ID=
